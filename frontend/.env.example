# API Configuration
# Local: http://localhost:8000
# Railway: https://backend-production-XXXX.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_V1_PREFIX=/api/v1

# NextAuth Configuration
# Local: http://localhost:3000
# Railway: https://frontend-production-XXXX.up.railway.app
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Google OAuth (get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Backend internal URL for server-to-server calls
# Railway: http://backend.railway.internal:8000
# BACKEND_INTERNAL_URL=
